CHIP FullAdder {
    IN a, b, c;  // 1-bit inputs
    OUT sum,     // Right bit of a + b + c
        carry;   // Left bit of a + b + c

    PARTS:
        HalfAdder(a=a , b=b , sum=aPb , carry= cone);
        HalfAdder(a= aPb, b=c , sum=sum , carry= ctwo);
        Or(a= cone, b=ctwo , out= carry);
}
